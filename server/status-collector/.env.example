# Shared secret for POST /ingest. ECS tasks must send this via Authorization: Bearer <token>
# If unset, ingest accepts all requests (for local dev only).
INGEST_TOKEN=

# Port to listen on (default: 8787)
PORT=8787

# Minutes of reports to treat as "active" for summary and task list (default: 2). Tasks that haven't reported within this window are excluded.
ACTIVE_WINDOW_MINUTES=2

# Traefik + Let's Encrypt
# Host for the status dashboard, e.g. status-dev.inzight.example.com
DOMAIN=status.localhost
# Email for Let's Encrypt ACME
ACME_EMAIL=admin@example.com
